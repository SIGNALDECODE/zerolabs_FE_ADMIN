# dev/prod 공통 — Nuxt 서버 프록시(server/api/[...].ts) 경유 (same-origin 우회)
# CSR 은 '/api' 로 호출 → Nuxt 서버가 받아서 API_BASE_URL 로 포워딩.

NUXT_PUBLIC_API_BASE=/api

# 프록시가 포워딩할 BE 절대 URL.
# dev: 로컬 또는 스테이징 BE
API_BASE_URL=http://localhost:9092/api/v1

# prod: Vercel 등 호스팅 환경변수에 BE prod 절대 URL 주입
# API_BASE_URL=https://<BE-prod-host>/api/v1
